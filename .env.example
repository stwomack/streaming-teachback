# ─── Anthropic ────────────────────────────────────────────────────────────────
# Required: your Anthropic API key. The streaming activity reads it from the env.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used for the streaming completion. Overridable; defaults to the PRD value.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=streams-mechanics

# ─── Bridge (FastAPI) ─────────────────────────────────────────────────────────
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8000

# ─── DEMO-ONLY SCAFFOLDING (leave unset for a normal run) ──────────────────────
# These knobs exist purely to stage the four failure/resume scenarios reliably in
# front of a live audience. NONE of them are production patterns.

# Scenario 2 (worker crash / activity retry): when the running token count reaches
# this value, the activity parks on a heartbeating sleep so the presenter has a
# wide, reliable window to SIGKILL the worker at a known point.
# DEMO_PAUSE_AT_TOKEN=40

# How long (seconds) the pause above holds before giving up and continuing.
# DEMO_PAUSE_SECONDS=120

# Scenario 1 (LLM API fails mid-stream): when the running token count reaches this
# value, the activity raises a simulated Anthropic error so you can watch the
# graceful fallback path publish a fallback event instead of crashing the workflow.
# DEMO_FORCE_LLM_ERROR_AT_TOKEN=30
